# 本番 Laravel .env の雛形。
# サーバ上で本ファイルを .env としてコピーし、値を埋めて配置する（.env は gitignore 済み）。
#   cp .env.production.example .env && php artisan key:generate（またはローカルで生成した APP_KEY を設定）
# DB の接続情報は .env.db（Postgres 側）と一致させること。

APP_NAME=MentalLog
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://mentallog.cde.jp

APP_LOCALE=ja
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=warning

# DB（サービス名 db に接続。認証情報は .env.db と揃える）
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=mentallog
DB_USERNAME=mentallog
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=log

# ===== Docker / ホスト側の設定 =====
# `cp .env.docker.example .env` して利用（docker compose が読み込む）

# ホストの UID/GID（Mac/Linux で `id -u` / `id -g` の値に合わせると権限ずれ回避）
UID=1000
GID=1000

# 公開ポート
APP_PORT=8080       # http://localhost:8080  (nginx)
ADMINER_PORT=8081   # http://localhost:8081  (Adminer)
DB_PORT=5432        # ホストからDB接続する場合

# ===== PostgreSQL（コンテナ & Laravel 共通）=====
DB_CONNECTION=pgsql
DB_HOST=db          # ★ Laravel の .env でも db を指定（サービス名）
DB_DATABASE=mentallog
DB_USERNAME=mentallog
DB_PASSWORD=secret
